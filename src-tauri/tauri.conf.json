{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gemma Diagram Brainstormer",
  "version": "0.1.0",
  "identifier": "dev.local.gemma-diagram-brainstormer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gemma Diagram Brainstormer",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
